{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "copilot",
	"main": "entry-cloudflare.ts",
	"compatibility_date": "2025-01-01",
	"account_id": "32fdecdd7a75ddb32f62581194a1030a",
