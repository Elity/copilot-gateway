		{ "pattern": "copilot.fighting.bid", "custom_domain": true }
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "copilot-db",
			"database_id": "dbec2c31-8d4a-4645-ac9c-50387b69ea20",
			"remote": true
		}
	]
}